# PrenotaMi account credentials
PRENOTAMI_EMAIL=your-email@example.com
PRENOTAMI_PASSWORD=your-password

# Email to receive notifications (defaults to PRENOTAMI_EMAIL if not set)
NOTIFY_EMAIL=your-email@example.com

# Check interval in seconds (default: 900 = 15 minutes)
CHECK_INTERVAL=900

# Cooldown between repeat notifications in seconds (default: 1800 = 30 minutes)
NOTIFY_COOLDOWN=1800

# Notification method: "macos_mail" (default)
NOTIFY_METHOD=macos_mail
